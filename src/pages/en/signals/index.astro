---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allSignals = await getCollection('signals');
const sortedSignals = allSignals.sort((a, b) => b.data.subscribers - a.data.subscribers);

const pageTitle = 'Global Signal Leaderboard | FX278 Terminal';
const pageDescription = 'Full directory of audited MQL5 and copy trading signals. Filter by drawdown, risk, and monthly return.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://fx278.com/en/signals/"
>
  <main class="bg-surface text-text min-h-screen py-16">
    <div class="container max-w-6xl mx-auto px-6">
      
      <header class="mb-10">
        <h1 class="text-3xl font-mono font-bold text-white uppercase mb-2">SYS_LEADERBOARD // ALL</h1>
        <p class="text-muted font-mono text-sm">Querying database: {sortedSignals.length} records found.</p>
      </header>

      <div class="bg-neutral border border-border font-mono text-sm overflow-x-auto shadow-2xl">
        <div class="grid grid-cols-7 border-b border-border text-muted uppercase p-4 min-w-[900px] bg-[#0d0d0d]">
          <div class="col-span-2">SYS_ID</div>
          <div>PLATFORM</div>
          <div>RISK</div>
          <div class="text-right">WIN_RATE</div>
          <div class="text-right">MONTHLY_RET</div>
          <div class="text-right">MAX_DD</div>
        </div>
        
        <div class="divide-y divide-border min-w-[900px]">
          {sortedSignals.length > 0 ? sortedSignals.map(signal => (
            <a href={`/en/signals/${signal.id.split('/').pop()}`} class="grid grid-cols-7 p-4 items-center hover:bg-[#1a1a1a] transition-colors group">
              <div class="col-span-2 flex flex-col">
                <span class="font-bold text-white group-hover:text-primary transition-colors">{signal.data.title}</span>
                <span class="text-xs text-muted">VOL: {signal.data.subscribers.toLocaleString()} subs</span>
              </div>
              <div class="text-muted">{signal.data.platform}</div>
              <div class={signal.data.riskLevel === 'High' ? 'text-accent' : 'text-primary'}>{signal.data.riskLevel}</div>
              <div class="text-right text-white">{signal.data.winRate}</div>
              <div class={`text-right font-bold ${signal.data.monthlyReturn.includes('-') ? 'text-accent' : 'text-primary'}`}>
                {signal.data.monthlyReturn}
              </div>
              <div class="text-right text-accent font-bold">
                {signal.data.maxDrawdown}
              </div>
            </a>
          )) : (
            <div class="p-12 text-center text-primary animate-pulse">
              [ ERROR: NO_RECORDS_FOUND ]
            </div>
          )}
        </div>
      </div>
      
    </div>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = 'FX278 — Forex Copy Trading & Social Signals';
const pageDescription = 'Follow the best professional traders. Reviews of ZuluTrade, MQL5 Signals, and Copy Trading platforms.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://fx278.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <Hero title="Copy the Top Forex Traders Automatically" subtitle="Discover the most profitable signal providers on MQL5 and Social Trading networks." />

  <section class="container mx-auto px-6 py-8 animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
      Popular Categories
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-fr">
      <Card title="MQL5 Signals" description="Verified MQL5 Providers" href="/en/categories/c1/" tag="Trending" featured={true} />
      <Card title="ZuluTrade" description="Best ZuluTrade Masters" href="/en/categories/c2/" tag="New" />
      <Card title="PAMM/MAM" description="Managed Forex Accounts" href="/en/categories/c3/" />
      <Card title="Crypto Signals" description="Automated Crypto Copy" href="/en/categories/c4/" />
    </div>
  </section>

  <section class="container mx-auto px-6 py-16 animate-fade-in-up" style="animation-delay: 0.4s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
      Latest Updates
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card title="Top 10 MQL5 Signals 2026" description="Read our latest in-depth review and analysis for 2026." href="/en/reviews/1/" rating={4.9} price="Verified" />
      <Card title="Is ZuluTrade Still Good?" description="A comprehensive breakdown of features, pricing, and pros/cons." href="/en/reviews/2/" rating={4.7} price="Top Choice" />
      <Card title="Best PAMM Accounts" description="Everything you need to know before making a decision." href="/en/reviews/3/" rating={4.5} price="Updated" />
    </div>
  </section>
</BaseLayout>

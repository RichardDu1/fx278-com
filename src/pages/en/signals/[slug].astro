---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const signals = await getCollection('signals');
  return signals.map(signal => ({
    params: { slug: signal.id.split('/').pop() },
    props: { signal },
  }));
}

const { signal } = Astro.props;
const { Content } = await render(signal);

// Schema Markup
const signalSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": signal.data.title,
  "description": signal.data.description
};
---

<BaseLayout
  title={`${signal.data.title} Signal Analysis | FX278`}
  description={signal.data.description}
  canonical={`https://fx278.com/en/signals/${signal.id.split('/').pop()}/`}
  schema={{ type: 'Product', data: signalSchema }}
>
  <div class="bg-surface text-text min-h-screen py-12 font-mono">
    <div class="container max-w-6xl mx-auto px-6">
      
      <!-- Breadcrumbs -->
      <nav class="mb-8 text-xs text-muted flex items-center gap-2">
        <a href="/en/signals/" class="hover:text-primary transition-colors">> SYS_LEADERBOARD</a>
        <span>/</span>
        <span class="text-white">{signal.data.title}</span>
      </nav>

      <!-- Terminal Header -->
      <header class="bg-neutral border border-border p-6 mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 shadow-xl">
        <div>
          <div class="text-primary text-xs uppercase tracking-widest mb-2 flex items-center gap-2">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
            {signal.data.platform} // ACTIVE
          </div>
          <h1 class="text-4xl font-bold text-white mb-2">{signal.data.title}</h1>
          <p class="text-muted text-sm max-w-xl">{signal.data.description}</p>
        </div>
        
        <div class="flex gap-6">
          <div class="text-right">
            <span class="block text-xs text-muted mb-1">MONTHLY_RET</span>
            <span class={`text-3xl font-bold ${signal.data.monthlyReturn.includes('-') ? 'text-accent' : 'text-primary'}`}>
              {signal.data.monthlyReturn}
            </span>
          </div>
          <div class="text-right">
            <span class="block text-xs text-muted mb-1">MAX_DD</span>
            <span class="text-3xl font-bold text-accent">
              {signal.data.maxDrawdown}
            </span>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left: Analysis Report -->
        <article class="lg:col-span-2">
          <div class="bg-neutral border border-border p-8 prose prose-invert max-w-none
            prose-headings:font-mono prose-headings:text-white
            prose-h2:text-xl prose-h2:uppercase prose-h2:border-b prose-h2:border-border prose-h2:pb-2
            prose-p:text-muted prose-p:text-sm prose-p:leading-relaxed
            prose-a:text-primary hover:prose-a:text-white
            prose-strong:text-primary">
            <Content />
          </div>
        </article>

        <!-- Right: Stats Panel -->
        <aside class="lg:col-span-1 space-y-6 text-sm">
          
          <div class="bg-neutral border border-border p-6">
            <h3 class="text-white font-bold mb-4 border-b border-border pb-2">> SYS_METRICS</h3>
            <ul class="space-y-4">
              <li class="flex justify-between">
                <span class="text-muted">RISK_LEVEL</span>
                <span class={`font-bold ${signal.data.riskLevel === 'High' ? 'text-accent' : 'text-primary'}`}>{signal.data.riskLevel}</span>
              </li>
              <li class="flex justify-between">
                <span class="text-muted">WIN_RATE</span>
                <span class="text-white font-bold">{signal.data.winRate}</span>
              </li>
              <li class="flex justify-between">
                <span class="text-muted">VOL_SUBS</span>
                <span class="text-white font-bold">{signal.data.subscribers.toLocaleString()}</span>
              </li>
            </ul>
          </div>

          <div class="bg-neutral border border-border p-6 border-l-4 border-l-primary">
            <h3 class="text-primary font-bold mb-2">> QUANT_VERDICT</h3>
            <p class="text-muted text-xs leading-relaxed">
              Based on historical tick data and drawdown variance, this system relies heavily on grid/martingale recovery. Capital preservation is not guaranteed. Run only on isolated VPS with strict equity stops.
            </p>
          </div>

          <a href="#" class="block w-full bg-primary text-surface text-center font-bold py-3 uppercase hover:bg-white transition-colors">
            [ EXECUTE_COPY_SCRIPT ]
          </a>

        </aside>
      </div>

    </div>
  </div>
</BaseLayout>
